{
  "pack_name": "ddbd_starter_asset_pack_v1",
  "project": "Dungeon Dive: Bad Decisions",
  "style_direction": "flat vector + distressed corporate grime",
  "ui_direction": "dark UI with horror accents",
  "accessibility_bias": "conservative clarity-first",
  "implementation_notes": {
    "preferred_format": "SVG-first with PNG fallbacks",
    "runtime_sizes_recommended": [
      "24dp",
      "28dp",
      "32dp"
    ],
    "touch_targets_min": "48dp",
    "do_not_use_color_only": true,
    "pair_status_icons_with_text_or_tooltip": true,
    "pair_route_nodes_with_label_or legend": true
  },
  "assumptions": [
    "The live build confirms 5 statuses, but the route/readme snapshot does not expose their names. This pack uses the first five authored status entries from the dedicated status pack: Hyped, Misbadged, Routed, Backlogged, Under Review.",
    "Enemy/miniboss named writing content remains provisional overlay and is not included in this starter icon pack.",
    "Assets are designed for portrait Android UI and dark-theme deployment."
