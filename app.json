{
  "expo": {
    "name": "Dungeon Dive: Bad Decisions",
    "slug": "dungeon-dive-bad-decisions",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/store/png/icon/ddbd_play_icon_default_512x512.png",
    "scheme": "dungeondivebaddecisions",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#220006",
        "foregroundImage": "./src/assets/store/png/icon/ddbd_play_icon_default_512x512.png",
        "monochromeImage": "./src/assets/store/png/icon/ddbd_play_icon_mono_512x512.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.moonlithe.dungeondivebaddecisions"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/store/png/icon/ddbd_play_icon_default_512x512.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/store/png/icon/ddbd_play_icon_default_512x512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#120104",
          "dark": {
            "backgroundColor": "#120104"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
